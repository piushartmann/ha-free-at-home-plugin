{
  "name": "ha-free-at-home-plugin",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "node build/main.js",
    "build": "tsc -p .",
    "postbuild": "npm run validate",
    "buildProd": "tsc  -p . --sourceMap false --declarationMap false",
    "postbuildProd": "npm run postbuild",
    "validate": "free-at-home-cli validate",
    "typecheck": "tsc -p . --noEmit",
    "prepack": "npm run buildProd",
    "pack": "free-at-home-cli buildscriptarchive build",
    "journal": ". ./.env && free-at-home-cli journal --filterAddon",
    "monitorstate": ". ./.env && free-at-home-cli addonapplicationstate --clear",
    "monitorconfig": ". ./.env && free-at-home-cli addonconfiguration --clear"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@busch-jaeger/free-at-home": "^0.33.2",
    "@types/ws": "^8.18.1",
    "home-assistant-js-websocket": "^9.6.0",
    "ts-mixer": "5.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@busch-jaeger/free-at-home-cli": "^0.9.1",
    "@tsconfig/node18": "^18.2.6",
    "@types/node": "^18.19.130",
    "typescript": "^5.9.3"
  }
}
